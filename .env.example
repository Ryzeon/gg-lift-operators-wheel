# Environment Variables Example
# Copy this file to .env.local for local development

# NODE_ENV should NOT be set to production during development
# NODE_ENV=development

# Optional: JSONBin.io for global history (shared across devices)
# 1. Create free account at https://jsonbin.io
# 2. Create a new bin with empty array [] as content
# 3. Copy bin ID from URL and API key from API Keys page
# Without these, history is stored locally in localStorage only
# VITE_JSONBIN_API_KEY=your-master-key
# VITE_JSONBIN_BIN_ID=your-bin-id
